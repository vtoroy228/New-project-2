generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String       @id @default(cuid())
  telegramId    BigInt       @unique
  username      String?
  avatarUrl     String?
  firstName     String
  lastName      String?
  isPremium     Boolean      @default(false)
  isBanned      Boolean      @default(false)
  bestScore     Int          @default(0)
  totalGames    Int          @default(0)
  totalScore    BigInt       @default(0)
  totalPlayTime Int          @default(0)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  gameResults   GameResult[]

  @@index([bestScore])
  @@index([isBanned, bestScore, updatedAt])
}

model GameResult {
  id         String   @id @default(cuid())
  userId     String
  score      Int
  playTime   Int
  obstacles  Int
  sessionId  String?
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([createdAt])
  @@unique([userId, sessionId])
}

model LeaderboardState {
  id             String   @id @default("global")
  epochStart     DateTime @default(now())
  latestBackupId String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model LeaderboardBackup {
  id                  String                 @id @default(cuid())
  createdAt           DateTime               @default(now())
  createdByTelegramId BigInt?
  confirmationMaxScore Int?
  maxScore            Int                    @default(0)
  usersCount          Int                    @default(0)
  previousEpochStart  DateTime
  restoredAt          DateTime?
  restoredByTelegramId BigInt?
  entries             LeaderboardBackupEntry[]

  @@index([createdAt])
}

model LeaderboardBackupEntry {
  id         String            @id @default(cuid())
  backupId   String
  userId     String
  telegramId BigInt
  username   String?
  avatarUrl  String?
  firstName  String
  lastName   String?
  bestScore  Int
  backup     LeaderboardBackup @relation(fields: [backupId], references: [id], onDelete: Cascade)

  @@index([backupId])
  @@index([userId])
  @@unique([backupId, userId])
}
