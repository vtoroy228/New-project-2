# Shared
NODE_ENV=development
PORT=3000
HOST=0.0.0.0
LOG_LEVEL=info
LOG_PRETTY=false
LOG_REQUESTS=true
AUTH_DEBUG_LOGS=false

# Deployment / Docker
APP_PORT=3000
DEPLOY_GIT_PULL=false
DEPLOY_GIT_REMOTE=origin
DEPLOY_GIT_BRANCH=main
# For Docker networking use db host instead of localhost:
# DATABASE_URL=postgresql://postgres:postgres@db:5432/telegram_dino?schema=public

# xtunnel watchdog (server)
XTUNNEL_ENABLED=true
XTUNNEL_BIN=xtunnel
XTUNNEL_PROTOCOL=http
XTUNNEL_PORT=3000
XTUNNEL_FORCE=true
XTUNNEL_LICENSE_KEY=YOUR_LICENSE_KEY
XTUNNEL_EXTRA_ARGS=
# Optional override if you need full custom command (quote if spaces):
# XTUNNEL_COMMAND="xtunnel http 3000 --force --license YOUR_LICENSE_KEY"
XTUNNEL_RESTART_MODE=daily
XTUNNEL_RESTART_DAILY_AT=04:00
XTUNNEL_RESTART_TIMEZONE=Europe/Moscow
# For daily mode: restart only after this many seconds without tunnel activity
XTUNNEL_DAILY_RESTART_IDLE_SECONDS=180
# Activity source file for idle check (default: XTUNNEL_LOG_FILE)
XTUNNEL_DAILY_RESTART_ACTIVITY_FILE=./logs/xtunnel.log
# Used only when XTUNNEL_RESTART_MODE=interval
XTUNNEL_RESTART_EVERY_MINUTES=180
XTUNNEL_RESTART_DELAY_SECONDS=5
XTUNNEL_LOG_FILE=./logs/xtunnel.log
XTUNNEL_SUPERVISOR_LOG_FILE=./logs/xtunnel-watchdog.log
XTUNNEL_WATCHDOG_PID_FILE=./.run/xtunnel-watchdog.pid

# Backend
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/telegram_dino?schema=public
TELEGRAM_BOT_TOKEN=123456:replace_me
TELEGRAM_MINI_APP_URL=
TELEGRAM_AUTH_MAX_AGE_SECONDS=300
TELEGRAM_VERIFY_CACHE_TTL_MS=30000
TELEGRAM_VERIFY_CACHE_MAX_ENTRIES=5000
LEADERBOARD_CACHE_TTL_MS=3000
ADMIN_TELEGRAM_IDS=123456789,987654321
TELEGRAM_ADMIN_BOT_ENABLED=false
TELEGRAM_ADMIN_HIDDEN_COMMAND=/__admin
TELEGRAM_ADMIN_BOT_AUTO_DELETE_WEBHOOK=false
TELEGRAM_ADMIN_XTUNNEL_RESTART_ENABLED=false
TELEGRAM_ADMIN_XTUNNEL_RESTART_COMMAND="bash ./ops/xtunnel-service.sh restart"
TELEGRAM_ADMIN_XTUNNEL_RESTART_TIMEOUT_MS=45000
TELEGRAM_ADMIN_XTUNNEL_RESTART_CONFIRMATION=RESTART XTUNNEL
TELEGRAM_ADMIN_BOT_POLL_TIMEOUT_SECONDS=25
TELEGRAM_ADMIN_BOT_POLL_REQUEST_TIMEOUT_MS=45000
DEV_MOCK_TELEGRAM=false
DEV_MOCK_USER_ID=10001
DEV_MOCK_USERNAME=dev_user
DEV_MOCK_FIRST_NAME=Dev
DEV_MOCK_LAST_NAME=Player
DEV_MOCK_IS_PREMIUM=false

# Frontend (Vite)
VITE_DEV_MOCK_TELEGRAM=false
VITE_DEV_MOCK_FIRST_NAME=Dev
VITE_DEV_MOCK_LAST_NAME=Player
VITE_DEV_MOCK_USERNAME=dev_user
