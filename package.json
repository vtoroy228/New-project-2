{
  "name": "telegram-dino-miniapp",
  "private": true,
  "version": "1.0.0",
  "workspaces": [
    "backend",
    "frontend"
  ],
  "scripts": {
    "dev": "concurrently -n backend,frontend -c cyan,magenta \"npm run dev --workspace backend\" \"npm run dev --workspace frontend\"",
    "build": "npm run build --workspace frontend && npm run build --workspace backend",
    "start": "npm run start --workspace backend",
    "xtunnel:run": "bash ./ops/xtunnel-loop.sh run",
    "xtunnel:start": "bash ./ops/xtunnel-loop.sh start",
    "xtunnel:stop": "bash ./ops/xtunnel-loop.sh stop",
    "xtunnel:restart": "bash ./ops/xtunnel-loop.sh restart",
    "xtunnel:status": "bash ./ops/xtunnel-loop.sh status",
    "admin:reset-leaderboard": "npm run admin:reset-leaderboard --workspace backend",
    "prisma:generate": "npm run prisma:generate --workspace backend",
    "prisma:migrate": "npm run prisma:migrate --workspace backend"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
